# 1. Dans le dossier de ton projet

git init

# 2. Ajouter les fichiers

git add .

# 3. Premier commit

git commit -m "Initial commit"

# 4. Créer le repo sur GitHub (via le site github.com)

# Puis relier ton dossier local au repo distant

git remote add origin https://github.com/ton-username/nom-du-repo.git

# 5. Push

git push -u origin main
